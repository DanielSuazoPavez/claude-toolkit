{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Claude Toolkit - Reference settings.json template",
  "_instructions": "Copy this to .claude/settings.json and customize for your project. Shared permissions are included below \u2014 for project-specific trust (skills, MCP tools, etc.), create .claude/settings.local.json (not committed to git).",
  "enableAllProjectMcpServers": false,
  "showClearContextOnPlanAccept": true,
  "plansDirectory": "output/claude-toolkit/plans",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(trash-put:*)",
      "Bash(jq:*)",
      "Bash(make:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git commit:*)",
      "Bash(./.claude/hooks/*)",
      "Bash(.claude/scripts/*)",
      "Bash(claude-toolkit:*)",
      "Glob(**)",
      "Grep(**)",
      "Read(/**)",
      "Write(/output/claude-toolkit/**)",
      "Edit(/output/claude-toolkit/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "EnterPlanMode|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/git-safety.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous-commands.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/enforce-uv-run.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/enforce-make-commands.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-config-edits.sh"
          }
        ]
      },
      {
        "matcher": "Read|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/secrets-guard.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/suggest-read-json.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/surface-lessons.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/approve-safe-commands.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --config=.claude/claude-powerline.json"
  },
  "_env_config": {
    "_note": "Environment variables used by hooks. Set in shell or .envrc to customize behavior.",
    "CLAUDE_DOCS_DIR": "Directory for docs (default: .claude/docs)",
    "CLAUDE_MEMORIES_DIR": "Directory for memories (default: .claude/memories)",
    "JSON_SIZE_THRESHOLD_KB": "Size threshold in KB for JSON blocking (default: 50)",
    "PROTECTED_BRANCHES": "Regex for protected branches (default: ^(main|master)$)"
  }
}
