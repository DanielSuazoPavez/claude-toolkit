# Claude Toolkit - Suggested .gitignore entries
# Add these lines to your project's .gitignore

# Claude Code session artifacts
output/claude-toolkit/

# Claude Code synced resources (managed by claude-toolkit sync)
.claude/

# Track project-specific config and memories
!.claude/settings.json
!.claude/mcp.json
!.claude/memories/*-project-*

# Global databases — should live in ~/.claude/, not in project
lessons.db
session-index.db
hooks.db

# Toolkit sync infrastructure
.claude-toolkit-version
