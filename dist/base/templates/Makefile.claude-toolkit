# Claude Toolkit - Suggested Makefile targets
# Merge these targets into your project's Makefile

# Lint and format (Python example - adjust for your stack)
.PHONY: help lint format test backlog

help:
	@echo "Available targets:"
	@echo "  make help                      - Show this help"
	@echo "  make lint                      - Run linters"
	@echo "  make test                      - Run tests"
	@echo "  make backlog                   - Show project backlog (hides P99 nice-to-haves — use 'claude-toolkit backlog' for all)"
	@echo "  make claude-toolkit-validate   - Run Claude toolkit validations"
	@echo "  make claude-toolkit-sync       - Sync Claude toolkit to project"

lint:
	pre-commit run --all-files

test:
	uv run pytest

backlog:
	@claude-toolkit backlog --exclude-priority P99

# Claude toolkit validation and sync
.PHONY: claude-toolkit-validate claude-toolkit-sync

claude-toolkit-validate:
	bash .claude/scripts/validate-all.sh

claude-toolkit-sync:
	claude-toolkit sync
