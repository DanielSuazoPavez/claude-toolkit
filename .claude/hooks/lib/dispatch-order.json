{
  "version": 1,
  "dispatchers": {
    "grouped-bash-guard": [
      "block-dangerous-commands",
      "block-destructive-sql",
      "auto-mode-shared-steps",
      "block-credential-exfiltration",
      "git-safety",
      "secrets-guard",
      "block-config-edits",
      "enforce-make-commands",
      "enforce-uv-run"
    ],
    "grouped-read-guard": [
      "secrets-guard",
      "suggest-read-json"
    ]
  },
  "index_order": [
    "session-start",
    "detect-session-start-truncation",
    "git-safety",
    "auto-mode-shared-steps",
    "block-credential-exfiltration",
    "block-dangerous-commands",
    "block-destructive-sql",
    "secrets-guard",
    "block-config-edits",
    "suggest-read-json",
    "enforce-uv-run",
    "enforce-make-commands",
    "surface-lessons",
    "approve-safe-commands",
    "log-tool-uses",
    "log-permission-denied",
    "grouped-bash-guard",
    "grouped-read-guard"
  ]
}
