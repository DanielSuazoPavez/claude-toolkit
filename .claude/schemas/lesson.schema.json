{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Lessons Database",
  "description": "Schema for .claude/learned.json — lessons captured across sessions",
  "type": "object",
  "required": ["lessons"],
  "additionalProperties": false,
  "properties": {
    "lessons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "date", "category", "flags", "tier", "text", "branch", "project"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique ID: {project}_{YYYYMMDD}T{HHMM}_{NNN}",
            "pattern": "^[a-z0-9_-]+_[0-9]{8}T[0-9]{4}_[0-9]{3}$"
          },
          "date": {
            "type": "string",
            "description": "Capture date (YYYY-MM-DD)",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "category": {
            "type": "string",
            "enum": ["correction", "pattern", "convention", "gotcha"]
          },
          "flags": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["recurring", "branch"]
            },
            "uniqueItems": true
          },
          "tier": {
            "type": "string",
            "enum": ["recent", "key", "historical"]
          },
          "text": {
            "type": "string",
            "description": "One-line actionable rule"
          },
          "branch": {
            "type": "string",
            "description": "Git branch at capture time"
          },
          "project": {
            "type": "string",
            "description": "Project name (git root basename)"
          },
          "promoted": {
            "type": ["string", "null"],
            "description": "Date when promoted to key tier (YYYY-MM-DD)",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "archived": {
            "type": ["string", "null"],
            "description": "Date when archived to historical tier (YYYY-MM-DD)",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          }
        }
      }
    }
  }
}
